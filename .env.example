# ==============================================================================
# Bulldog Alpha - Local Development Environment Flags File
# ==============================================================================
# Copy this file to '.env' in the same directory to customize your local configuration:
#   cp .env.example .env
#
# Docker Compose will automatically detect and load settings from your '.env' file.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Markets Data Feed Configuration
# ------------------------------------------------------------------------------
# Mock Feed (Default): ws://bff:8080/polygon
# Real Alpaca.io IEX Stocks Feed: wss://stream.data.alpaca.markets/v2/iex
# Real Polygon.io Delayed Stocks Feed: wss://delayed.polygon.io/stocks
FEED_URL=ws://bff:8080/polygon

# Market Data Feed Vendor (polygon, alpaca)
FEED_VENDOR=polygon

# ------------------------------------------------------------------------------
# 2. Authentication Keys
# ------------------------------------------------------------------------------
# Your personal Feed API Key
# - For Alpaca: format as "KEY_ID:SECRET_KEY" (e.g. PKXXXX:XXXXXX)
# - For Polygon: format as "YOUR_API_KEY"
# - Leave empty if using Mock Feed
FEED_API_KEY=
